generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id
  name         String
  email        String       @unique
  passwordHash String       @map("password_hash")
  emailVerifiedAt DateTime? @map("email_verified_at")
  memberships  Membership[]
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@map("users")
}

model Household {
  id                    String       @id
  name                  String
  inviteCode            String       @unique @map("invite_code")
  pantryJson            String       @default("[]") @map("pantry_json")
  budgetIncome          Int          @default(6200) @map("budget_income")
  budgetFamilySize      Int          @default(4) @map("budget_family_size")
  budgetGoal            String       @default("savings") @map("budget_goal")
  budgetStyle           String       @default("balanced") @map("budget_style")
  choresJson            String       @default("[]") @map("chores_json")
  remindersJson         String       @default("[]") @map("reminders_json")
  routinesJson          String       @default("[]") @map("routines_json")
  memberProfilesJson    String       @default("[]") @map("member_profiles_json")
  familyAchievementsJson String      @default("[]") @map("family_achievements_json")
  directThreadsJson     String       @default("[]") @map("direct_threads_json")
  partnerSpaceJson      String?      @map("partner_space_json")
  notificationsJson     String       @default("[]") @map("notifications_json")
  familyQuestBoardJson  String       @default("{\"sharedPoints\":0,\"lifetimeSharedPoints\":0,\"quests\":[],\"rewards\":[]}") @map("family_quest_board_json")
  gameRoomJson          String       @default("{\"selectedArcadeMemberId\":null,\"arcadeRuns\":[],\"uno\":null}") @map("game_room_json")
  assistantHistoryJson  String       @default("[]") @map("assistant_history_json")
  latestMealPlanJson    String?      @map("latest_meal_plan_json")
  latestBudgetCoachJson String?      @map("latest_budget_coach_json")
  memberships           Membership[]
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  @@map("households")
}

model Membership {
  id          String    @id
  userId      String    @map("user_id")
  householdId String    @map("household_id")
  role        String    @default("member")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([userId, householdId])
  @@map("memberships")
}
